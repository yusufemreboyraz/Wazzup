generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String
  passwordHash        String
  publicKey           String
  encryptedPrivateKey String
  createdAt           DateTime @default(now())

  sentEmails     Email[] @relation("SentEmails")
  receivedEmails Email[] @relation("ReceivedEmails")
}

model Email {
  id          String @id @default(uuid())
  senderId    String
  recipientId String

  // Confidentiality
  encryptedContent String
  encryptedAesKey  String // The AES key encrypted with Recipient's Public Key
  iv               String // IV for AES encryption

  // Integrity & Authenticity
  signature   String // Signature of the Message Hash by Sender's Private Key
  messageHash String // Hash of the original content

  read       Boolean  @default(false)
  isStarred  Boolean  @default(false)
  isArchived Boolean  @default(false)
  timestamp  DateTime @default(now())

  sender    User @relation("SentEmails", fields: [senderId], references: [id])
  recipient User @relation("ReceivedEmails", fields: [recipientId], references: [id])

  attachments Attachment[]
}

model Attachment {
  id      String @id @default(uuid())
  emailId String
  email   Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)

  filename         String
  contentType      String
  size             Int
  encryptedContent String // Base64 encoded encrypted content
  iv               String

  createdAt DateTime @default(now())
}
